VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# AWS Amplify — AppSync GraphQL (photo-008 backend)
# Get these from: AWS Amplify Console → photo-008 → Backend → Data → AppSync API
VITE_AMPLIFY_REGION=us-east-1
VITE_AMPLIFY_API_ENDPOINT=https://xxxxxxxxxx.appsync-api.us-east-1.amazonaws.com/graphql
VITE_AMPLIFY_API_KEY=da2-xxxxxxxxxxxxxxxxxxxx

# AWS S3 Storage — get from amplify_outputs.json → storage.bucket_name
VITE_AMPLIFY_STORAGE_BUCKET=amplify-xxxxxxxxxx-storage-xxxxxxxxxx
# Cognito Identity Pool — get from amplify_outputs.json → auth.identity_pool_id
VITE_AMPLIFY_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
